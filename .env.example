# URL del Web App de Google Apps Script (recibir leads).
# Obtener la URL después de desplegar el script en tu Google Sheet.
LEAD_FORM_URL=https://script.google.com/macros/s/XXXXXXXX/exec

# Monday.com — crear item al recibir un lead (mismo flujo en local y en Vercel)
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=

# Solo desarrollo local si falla SSL (UNABLE_TO_VERIFY_LEAF_SIGNATURE en Windows).
# Afecta Google Sheets, Monday y PVGIS (re.jrc.ec.europa.eu).
# Alternativa: `npm run dev` ya arranca Node con --use-system-ca.
# LEAD_SKIP_TLS_VERIFY=true

# SolarCheck admin (relevamiento)
ADMIN_USER=admin
ADMIN_PASS=changeme

# Vercel Blob: fotos del relevamiento, PDFs del cotizador y borradores de proyectos (/cotizador).
# En producción (Vercel) se usa Blob si hay token. En local/test siempre disco (data/cotizador-projects/).
# Forzar modo: COTIZADOR_STORAGE=local | blob (solo útil para probar Blob en local con red OK).
# BLOB_READ_WRITE_TOKEN=

# ── Cotizador Solar (herramienta interna /cotizador) ────────────────────────
# Password compartida del equipo comercial. Si está vacía, /cotizador queda sin protección (solo dev local).
APP_PASSWORD=

# Lectura de precios + registro de cotizaciones en Google Sheets.
# JSON completo del service account (una sola línea). El Sheet debe compartirse con el email del service account.
# Sin estas variables, el cotizador usa un catálogo mock para desarrollo.
GOOGLE_SERVICE_ACCOUNT_JSON=
PRICING_SHEET_ID=

# Envío del Reporte de Producción por mail (Resend). Sin esto, el botón avisa pero no rompe.
RESEND_API_KEY=
MAIL_FROM=Renovatio <reportes@tudominio.com>
# Copia interna opcional de cada envío
MAIL_BCC_INTERNO=
